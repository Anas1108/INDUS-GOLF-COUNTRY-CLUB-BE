# Server Port Configuration
PORT=5000

# MongoDB Atlas Connection URI
# Replace with your actual database connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/indus_golf_club?retryWrites=true&w=majority

# JWT Authentication Configuration
JWT_SECRET=your_jwt_secret_key_here

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Frontend URL (used for CORS origin restriction)
FRONTEND_URL=http://localhost:3000

# Seed Script Credentials (only needed when running npm run seed)
SEED_ADMIN_USER=your_admin_username
SEED_ADMIN_PASS=your_strong_password_here
